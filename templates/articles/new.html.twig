{% extends 'base.html.twig' %}

{% block title %}Nouvel article{% endblock %}

{% block body %}

<h1 class="mb-4">Créer un article</h1>

{{ form_start(form) }}

    {{ form_row(form.nom) }}
    {{ form_row(form.prix) }}

    {# AJOUT catégorie #}
    {{ form_row(form.category) }}

    {# bouton en dernier #}
    <div class="mt-3">
        {{ form_row(form.save) }}
    </div>

{{ form_end(form) }}

<p class="mt-3">
    <a href="{{ path('article_index') }}" class="btn btn-link">Annuler</a>
</p>

{% endblock %}