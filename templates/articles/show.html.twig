{% extends 'base.html.twig' %}

{% block title %}Détails article{% endblock %}

{% block body %}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>{{ article.nom }}</h2>

        <div>
            <a href="{{ path('article_index') }}" class="btn btn-outline-secondary btn-sm">
                ← Retour
            </a>

            <a href="{{ path('article_edit', {id: article.id}) }}" class="btn btn-primary btn-sm">
                Modifier
            </a>
        </div>

    </div>

    <div class="card shadow-sm p-3">

        <div class="row">

            <div class="col-md-6">

                <p><strong>ID :</strong> {{ article.id }}</p>

                <p><strong>Nom :</strong> {{ article.nom }}</p>

                <p><strong>Prix :</strong> {{ article.prix }} TND</p>

                <p>
                    <strong>Catégorie :</strong>
                    {{ article.category ? article.category.titre : 'Non définie' }}
                </p>

            </div>

        </div>

    </div>

    <form method="post"
          action="{{ path('article_delete', {id: article.id}) }}"
          onsubmit="return confirm('Voulez-vous vraiment supprimer cet article ?');"
          class="mt-3">

        <input type="hidden" name="_method" value="DELETE">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">

        <button class="btn btn-danger">
            Supprimer
        </button>

    </form>

</div>

{% endblock %}