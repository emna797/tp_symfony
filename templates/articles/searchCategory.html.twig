{% extends 'base.html.twig' %}

{% block title %}Recherche par catégorie{% endblock %}

{% block body %}

<div class="container mt-4">

    <h2 class="mb-4">Recherche des articles par catégorie</h2>

    <div class="card p-3 mb-4">

        {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.category) }}
            {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
        </div>

        <button class="btn btn-primary">Rechercher</button>

        {{ form_end(form) }}

    </div>

    <div class="row">

        {% for article in articles %}

            <div class="col-md-4 mb-3">

                <div class="card shadow-sm">

                    <div class="card-body">

                        <h5 class="card-title">{{ article.nom }}</h5>

                        <p class="card-text">
                            Prix : <strong>{{ article.prix }} TND</strong>
                        </p>

                        {% if article.category %}
                            <p class="text-muted">
                                Catégorie : {{ article.category.titre }}
                            </p>
                        {% endif %}

                        <a href="{{ path('article_show', {id: article.id}) }}" class="btn btn-sm btn-info">
                            Voir
                        </a>

                    </div>

                </div>

            </div>

        {% else %}

            <div class="alert alert-warning">
                Aucun article trouvé pour cette catégorie
            </div>

        {% endfor %}

    </div>

</div>

{% endblock %}